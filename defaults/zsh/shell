# Set complete path
export PATH="./bin:$HOME/.local/bin:$HOME/.local/share/btw/bin:$PATH"

export BTW_PATH="$HOME/.local/share/btw"

# Zsh-specific settings (skip if not running in zsh)
if [ -n "$ZSH_VERSION" ]; then
  # History control
  HISTFILE=~/.zsh_history
  HISTSIZE=32768
  SAVEHIST="${HISTSIZE}"
  setopt HIST_IGNORE_ALL_DUPS
  setopt HIST_IGNORE_SPACE
  setopt SHARE_HISTORY
  setopt APPEND_HISTORY

  # Autocompletion
  autoload -Uz compinit && compinit
fi
