# History control
HISTFILE=~/.zsh_history
HISTSIZE=32768
SAVEHIST="${HISTSIZE}"
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY

# Autocompletion
autoload -Uz compinit && compinit

# Set complete path
export PATH="./bin:$HOME/.local/bin:$HOME/.local/share/btw/bin:$PATH"

export BTW_PATH="$HOME/.local/share/btw"
